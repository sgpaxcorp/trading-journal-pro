{
  "expo": {
    "name": "Neuro Trader",
    "slug": "neuro-trader",
    "scheme": "com.sgpax.neurotraderjournal",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/neurotrader-logo-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sgpax.neurotraderjournal",
      "appleTeamId": "2BWGA2LDRC",
      "associatedDomains": [
        "applinks:www.neurotrader-journal.com",
        "applinks:neurotrader-journal.com"
      ],
      "infoPlist": {
        "CFBundleDisplayName": "Neuro Trader",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "3"
    },
    "android": {
      "package": "com.sgpax.neurotraderjournal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.neurotrader-journal.com"
            },
            {
              "scheme": "https",
              "host": "neurotrader-journal.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "./plugins/with-device-debug-bundling",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "323bd3c3-8378-43a9-b50b-157c6cfd1059"
      }
    },
    "owner": "stevenotero"
  }
}
