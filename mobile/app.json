{
  "expo": {
    "name": "Neuro Trader",
    "slug": "neuro-trader",
    "scheme": "com.sgpax.neurotraderjournal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/neurotrader-logo-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/neurotrader-logo-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sgpax.neurotraderjournal",
      "appleTeamId": "2BWGA2LDRC",
      "infoPlist": {
        "CFBundleDisplayName": "Neuro Trader"
      },
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/neurotrader-logo-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "./plugins/with-device-debug-bundling"
    ]
  }
}
