{
  "expo": {
    "name": "Neuro Trader",
    "slug": "neuro-trader",
    "scheme": "com.sgpax.neurotraderjournal",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/neurotrader-logo-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sgpax.neurotraderjournal",
      "appleTeamId": "2BWGA2LDRC",
      "infoPlist": {
        "CFBundleDisplayName": "Neuro Trader"
      },
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "./plugins/with-device-debug-bundling",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "323bd3c3-8378-43a9-b50b-157c6cfd1059"
      }
    },
    "owner": "stevenotero"
  }
}
