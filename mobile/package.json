{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:release": "npm run version:bump && expo run:ios --device --configuration Release",
    "ios:release:marketing": "npm run version:bump:marketing && expo run:ios --device --configuration Release",
    "ios:prebuild": "expo prebuild --platform ios --clean",
    "ios:sync-native": "expo prebuild --platform ios --no-install && npx pod-install ios",
    "ios:clean-run": "./scripts/ios-clean-run.sh",
    "ios:prepare-archive": "npm run version:bump && npm run ios:sync-native",
    "version:bump": "node ./scripts/bump-version.js",
    "version:bump:marketing": "node ./scripts/bump-version.js --marketing",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~54.0.33",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "@stripe/stripe-react-native": "^0.36.0",
    "expo-constants": "~17.1.6",
    "expo-device": "~8.0.8",
    "expo-notifications": "~0.31.5",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
